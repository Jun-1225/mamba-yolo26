# 使用方法：复制本文件为同目录下的 .env，填入你的密钥（勿提交 .env）。
#
# DeepSeek 接口基址须带 /v1，例如：https://api.deepseek.com/v1
# 若只写 https://api.deepseek.com，程序会自动补全为 .../v1

# ---------- DeepSeek（推荐）----------
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# 同时存在 OPENAI 与 DeepSeek 密钥时，指定用哪一个（deepseek | openai）
# BRIDGE_LLM_PROVIDER=deepseek

# ---------- OpenAI 或其它兼容网关 ----------
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# ---------- 可选：ONNX ----------
# BRIDGE_MODEL_ONNX=/path/to/best.onnx
# BRIDGE_ONNX_DEVICE=cpu
# GPU：ORT 1.18 需 CUDA11 的 pip 库（cublas/cudart/cufft 等），见 requirements-onnx-gpu-cudnn8.txt；建议用 ./run_uvicorn_gpu.sh
# BRIDGE_ONNX_DEVICE=cuda:0
# 分割模型默认 task=segment；若要 Ultralytics 自动猜任务可设 BRIDGE_YOLO_TASK=auto
# BRIDGE_YOLO_TASK=segment
